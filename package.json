{
  "name": "advicely-random-deck",
  "version": "6.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "typegen": "node ./scripts/prepare-typegen.mjs && next typegen",
    "typecheck": "pnpm run typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "audit:high": "pnpm audit --audit-level high",
    "docs:lint": "markdownlint-cli2 README.md docs/**/*.md",
    "docs:mermaid": "node ./scripts/check-mermaid.mjs",
    "docs:check": "pnpm run docs:lint && pnpm run docs:mermaid"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.8.4",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "browserslist": [
    "chrome 111",
    "edge 111",
    "firefox 111",
    "safari 16.4"
  ],
  "pnpm": {
    "ignoredOptionalDependencies": [
      "jsdom"
    ]
  }
}
