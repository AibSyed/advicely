{
  "name": "advicely-random-deck",
  "version": "6.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typegen": "node ./scripts/prepare-typegen.mjs && next typegen",
    "typecheck": "pnpm run typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "audit:high": "pnpm audit --audit-level high",
    "docs:lint": "markdownlint-cli2 README.md docs/**/*.md",
    "docs:links": "markdown-link-check README.md && markdown-link-check docs/architecture.md",
    "docs:mermaid": "node ./scripts/check-mermaid.mjs",
    "docs:check": "pnpm run docs:lint && pnpm run docs:links && pnpm run docs:mermaid"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^29.0.0",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "browserslist": [
    "chrome 111",
    "edge 111",
    "firefox 111",
    "safari 16.4"
  ]
}
