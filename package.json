{
  "name": "advicely-coach",
  "version": "3.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "audit:high": "pnpm audit --audit-level high",
    "docs:lint": "markdownlint-cli2 README.md docs/**/*.md",
    "docs:mermaid": "node ./scripts/check-mermaid.mjs",
    "docs:check": "pnpm run docs:lint && pnpm run docs:mermaid"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "canvas-confetti": "^1.9.3",
    "framer-motion": "^12.23.24",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.65.0",
    "react-icons": "^5.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28.1.0",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
